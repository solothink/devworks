
{
  "entities": {
    "ProjectRequirement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProjectRequirement",
      "type": "object",
      "description": "Represents a project requirement submission from a potential client.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the submission."
        },
        "clientName": {
          "type": "string"
        },
        "clientEmail": {
          "type": "string",
          "format": "email"
        },
        "budgetRange": {
          "type": "string"
        },
        "projectDescription": {
          "type": "string"
        },
        "submissionDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "clientName",
        "clientEmail",
        "projectDescription",
        "submissionDate"
      ]
    },
    "ContactMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContactMessage",
      "type": "object",
      "description": "Represents a general contact inquiry.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "message": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "email", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/project_requirements/{projectRequirementId}",
        "definition": {
          "entityName": "ProjectRequirement",
          "schema": {
            "$ref": "#/backend/entities/ProjectRequirement"
          },
          "description": "Stores project leads for quotes."
        }
      },
      {
        "path": "/contact_messages/{messageId}",
        "definition": {
          "entityName": "ContactMessage",
          "schema": {
            "$ref": "#/backend/entities/ContactMessage"
          },
          "description": "Stores general contact form messages."
        }
      },
      {
        "path": "/roles_admin/{adminUid}",
        "definition": {
          "entityName": "AdminRole",
          "description": "Grants admin privileges based on UID existence."
        }
      }
    ]
  }
}
